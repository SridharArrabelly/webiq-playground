# --- WebIQ search (one of: API key OR Entra ID) ---
WEBIQ_API_KEY=replace-me-with-your-key
# If WEBIQ_API_KEY is unset, both the SDK and MCP backends fall back to Entra ID via
# DefaultAzureCredential (install with: uv sync --extra entra).

# --- Backend selection ---
# Which access method the CLI/agent use: sdk (default) or mcp. Override per-run with
# `webiq --backend mcp ...`.
WEBIQ_BACKEND=sdk
# MCP backend only (uv sync --extra mcp). Override the WebIQ MCP server endpoint:
# WEBIQ_MCP_ENDPOINT=https://api.microsoft.ai/v3/mcp

# --- Foundry grounding agent (uv sync --extra agent) ---
FOUNDRY_PROJECT_ENDPOINT=https://foundry-resource-zanorth-01.services.ai.azure.com/api/projects/webiq-websearch
FOUNDRY_MODEL_NAME=gpt-4o
# Optional per-feature agent name override (default: webiq-<feature>-agent):
# FOUNDRY_AGENT_NAME_WEB=webiq-web-agent
