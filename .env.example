# Required for the quick-start (API key) auth path.
WEBIQ_API_KEY=replace-me-with-your-key

# Optional: Entra ID (OAuth2 client credentials) auth path.
# If WEBIQ_API_KEY is unset and all three below are set, the client
# requests a bearer token via MSAL (install with: uv sync --extra entra).
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=6ecede09-2bc9-46da-afdc-62fb9d1c2167
# AZURE_CLIENT_SECRET=
